# Deno lockfile — generated by local `deno check/test` runs against
# supabase/functions/deno.json; CI runs lockfile-less (--node-modules-dir=none)
deno.lock

# Generated by scripts/vendor-function-deps.mjs (#339) — copies of packages/*/src that
# supabase/functions/deno.json's import map points at, since Supabase's function bundler
# (local or deployed) can't see files outside supabase/functions/.
supabase/functions/_vendor/
__pycache__/
