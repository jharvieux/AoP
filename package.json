{
  "name": "aop",
  "private": true,
  "version": "0.0.1",
  "description": "Age of Plunder — pirate strategy game",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @aop/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm format:check && pnpm typecheck && pnpm test && pnpm build",
    "verify:fast": "pnpm format:check && pnpm typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20"
  }
}
