# Supabase environment. See supabase/README.md for how these map to local dev vs. a
# real project, and docs/MULTIPLAYER.md for what each key is used for.

# Local dev: printed by `pnpm supabase:start` (or `supabase status` while it's running).
# Staging/production: Project Settings > API in the Supabase dashboard for that project.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Service-role key: server-side only (Edge Functions). Never expose to the client bundle
# or commit a real value — this bypasses row-level security entirely.
SUPABASE_SERVICE_ROLE_KEY=

# Vite only exposes env vars prefixed VITE_ to client code; mirror the two public values
# under this prefix for apps/web.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
