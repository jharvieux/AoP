# Supabase environment. See supabase/README.md for how these map to local dev vs. a
# real project, and docs/MULTIPLAYER.md for what each key is used for.

# Local dev: printed by `pnpm supabase:start` (or `supabase status` while it's running).
# Staging/production: Project Settings > API in the Supabase dashboard for that project.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Service-role key: server-side only (Edge Functions). Never expose to the client bundle
# or commit a real value — this bypasses row-level security entirely.
SUPABASE_SERVICE_ROLE_KEY=

# Vite only exposes env vars prefixed VITE_ to client code; mirror the two public values
# under this prefix for apps/web.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web ads (docs/ARCHITECTURE.md §9). Both optional — unset means <AdSlot> (see
# apps/web/src/AdSlot.tsx) renders nothing on web, same as when the viewer holds
# the remove_ads entitlement.
VITE_AD_NETWORK_SCRIPT_URL=
VITE_AD_NETWORK_SLOT_ID=

# Stripe remove-ads purchase (docs/ARCHITECTURE.md §9). Edge Function secrets
# only — never exposed to the client bundle (see supabase/functions/README.md
# "Monetization"). STRIPE_REMOVE_ADS_PRICE_ID is the Price id for the one-time
# "remove ads" product created in the Stripe dashboard; STRIPE_WEBHOOK_SECRET
# comes from that dashboard's webhook endpoint config for stripe-webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_REMOVE_ADS_PRICE_ID=
